# Copy this file to .env and fill in your Supabase project values.
# Find them in your Supabase dashboard: Project Settings → API.
# These EXPO_PUBLIC_ vars are embedded in the client bundle (not secret) —
# data is protected by Row Level Security, not by hiding these.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — enables Spoonacular as a second recipe source (spoonacular.com/food-api).
# NOTE: unlike the Supabase anon key, this IS a secret. Embedding it in a client
# bundle exposes it; for production, proxy these calls through a backend.
EXPO_PUBLIC_SPOONACULAR_API_KEY=YOUR-SPOONACULAR-KEY
