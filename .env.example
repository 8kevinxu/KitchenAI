# Copy this file to .env and fill in your Supabase project values.
# Find them in your Supabase dashboard: Project Settings → API.
# These EXPO_PUBLIC_ vars are embedded in the client bundle (not secret) —
# data is protected by Row Level Security, not by hiding these.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Spoonacular (optional second recipe source) is reached through the Supabase
# Edge Function in supabase/functions/spoonacular. The API key is NOT a client
# env var — set it as a server secret instead:
#   supabase secrets set SPOONACULAR_API_KEY=your-key
# (or in the dashboard: Edge Functions → Secrets). No client config needed.
